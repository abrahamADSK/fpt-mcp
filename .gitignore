__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.env
.venv/
venv/
*.egg
.mypy_cache/
.pytest_cache/

# Claude Code local settings (user-specific paths)
.claude/

# Generated plist files (setup_venv.sh creates them dynamically)
*.plist

# Generated .app bundles
*.app/
.DS_Store

# RAG build artifacts (regenerate with: python -m fpt_mcp.rag.build_index)
src/fpt_mcp/rag/index/
src/fpt_mcp/rag/corpus.json

# learn_pattern staging file for untrusted models — runtime-generated, unbounded
# (one entry per staged pattern), never part of the tracked tree.
src/fpt_mcp/rag/candidates.json

# Coverage artifact from pytest-cov
.coverage

# Local runtime config (OPSEC): config.json holds machine-specific hosts
# (LAN Ollama URL on glorfindel, etc.) and must stay local. config.example.json
# is the tracked template; copy it to config.json on install. See docs/DEPLOY.md.
src/fpt_mcp/config.json

# F0 telemetry runtime stream (3C Wave 2) — regenerated by the server at runtime
logs/
