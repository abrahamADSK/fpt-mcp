{
  "mcpServers": {
    "fpt-mcp": {
      "command": "python",
      "args": ["-m", "fpt_mcp.server"],
      "cwd": "/path/to/fpt-mcp/src",
      "env": {
        "SHOTGRID_URL": "https://yoursite.shotgrid.autodesk.com",
        "SHOTGRID_SCRIPT_NAME": "your_script_name",
        "SHOTGRID_SCRIPT_KEY": "your_script_key",
        "SHOTGRID_PROJECT_ID": "0"
      }
    }
  }
}
