SHOTGRID_URL=https://YOUR_SITE.shotgrid.autodesk.com
SHOTGRID_SCRIPT_NAME=your_script_name
SHOTGRID_SCRIPT_KEY=your_script_key
SHOTGRID_PROJECT_ID=0

# Toolkit path template (hybrid mode)
# Uses {project}, {asset_type}, {asset}, {step}, {version} placeholders
TOOLKIT_ROOT=/mnt/projects
TOOLKIT_ASSET_PATH={project}/assets/{asset_type}/{asset}/{step}
TOOLKIT_SHOT_PATH={project}/sequences/{sequence}/{shot}/{step}
TOOLKIT_PUBLISH_PATH={project}/publishes/{entity_type}/{entity}/{step}/{name}/v{version}
