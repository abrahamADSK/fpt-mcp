SHOTGRID_URL=https://YOUR_SITE.shotgrid.autodesk.com
SHOTGRID_SCRIPT_NAME=your_script_name
SHOTGRID_SCRIPT_KEY=your_script_key
SHOTGRID_PROJECT_ID=0

# Toolkit path resolution — two modes:
#
# MODE 1 — Automatic (recommended if you have Advanced Project Setup):
#   Leave PUBLISH_ROOT empty. The server queries the PipelineConfiguration
#   from ShotGrid and reads templates.yml + roots.yml from the local config.
#   Works with local configs and 'dev' descriptor distributed configs.
#
# MODE 2 — Fallback (projects without Advanced Setup):
#   Set PUBLISH_ROOT to the directory where publishes should live.
#   The server uses tk-config-default2 standard templates:
#     assets/{sg_asset_type}/{Asset}/{Step}/publish/{tool}/{name}.v{version}.{ext}
#     sequences/{Sequence}/{Shot}/{Step}/publish/{tool}/{name}.v{version}.{ext}
#
PUBLISH_ROOT=
