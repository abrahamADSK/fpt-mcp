SHOTGRID_URL=https://YOUR_SITE.shotgrid.autodesk.com
SHOTGRID_SCRIPT_NAME=your_script_name
SHOTGRID_SCRIPT_KEY=your_script_key
SHOTGRID_PROJECT_ID=0

# Toolkit path resolution:
#
# If the project has an Advanced Setup (PipelineConfiguration entity in ShotGrid),
# the server reads templates.yml + roots.yml from the local config automatically.
#
# If the project does NOT have a PipelineConfiguration, tk_publish requires
# an explicit publish_path parameter. The path is stored in the PublishedFile
# entity. If the project has a Local File Storage in ShotGrid (File Management
# preferences), the file will be browsable from the web UI.
