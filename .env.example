SHOTGRID_URL=https://YOUR_SITE.shotgrid.autodesk.com
SHOTGRID_SCRIPT_NAME=your_script_name
SHOTGRID_SCRIPT_KEY=your_script_key
SHOTGRID_PROJECT_ID=0

# Toolkit path resolution:
#
# If the project has an Advanced Setup (PipelineConfiguration entity in ShotGrid),
# the server reads templates.yml + roots.yml from the local config automatically.
#
# If the project does NOT have a PipelineConfiguration, tk_publish requires
# an explicit publish_path parameter. The path is stored in the PublishedFile
# entity. If the project has a Local File Storage in ShotGrid (File Management
# preferences), the file will be browsable from the web UI.

# Write-path containment (tk_publish / sg_download):
#
# These tools anchor every write destination on a legitimate project root
# before writing. Allowed roots = the discovered TkConfig.project_root (when a
# PipelineConfiguration resolves) UNION the list below.
#
# FPT_MCP_ALLOWED_WRITE_ROOTS — os.pathsep-separated absolute roots that writes
#   are permitted under (use ':' on macOS/Linux). Leave unset to rely solely on
#   the discovered project root.
# FPT_MCP_ALLOWED_WRITE_ROOTS=/jobs:/mnt/projects
#
# FPT_MCP_STRICT_PATHS — set to 1 to REFUSE out-of-root destinations (nothing is
#   written). Default (unset) is warn-and-allow: the destination is logged and
#   the write proceeds, so no existing workflow breaks.
# FPT_MCP_STRICT_PATHS=1
